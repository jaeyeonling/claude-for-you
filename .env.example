# --- Server ---
PORT=3456
# 0.0.0.0 for container deployments. 127.0.0.1 for local dev.
HOST=0.0.0.0

# --- Anthropic OAuth credentials ---
# ⚠️  WARNING: `claude /logout` on ANY machine using these tokens triggers
# server-side revoke for the SAME refresh token here too — both die together.
# See docs/operational-pitfalls.md §1 before rotating.
#

# Two modes — pick one:
#
# A) SINGLE ACCOUNT (env vars below). Default. Required vars:
#    ANTHROPIC_OAUTH_REFRESH_TOKEN
#
# B) MULTI-ACCOUNT POOL (Phase 20a). Set ACCOUNTS_PATH and provide a JSON
#    file at that path with shape:
#      { "accounts": [
#          { "name": "work",     "refreshToken": "sk-ant-ort01-...", "accessToken": "...", "expiresAt": 1778... },
#          { "name": "personal", "refreshToken": "..." }
#      ] }
#    The pool routes each request to the member with the highest known
#    headroom; same x-claude-code-session-id sticks to the same account so
#    Anthropic's prompt cache stays warm.
#    When ACCOUNTS_PATH points at an existing valid file, single-account
#    env vars below are IGNORED.
ACCOUNTS_PATH=./data/accounts.json

# Obtained from your Claude.ai session. Refresh token is what we use to mint
# fresh access tokens; access token is the bearer we forward upstream.
ANTHROPIC_OAUTH_REFRESH_TOKEN=
ANTHROPIC_OAUTH_ACCESS_TOKEN=
ANTHROPIC_OAUTH_EXPIRES_AT=

# Persistent token store. Refreshed tokens are written atomically here (0600).
# Mount this path as a Docker volume for survival across container restarts.
TOKEN_STORE_PATH=./data/tokens.json

# --- API keys for trusted users ---
# Format: name1:key1,name2:key2
# Each key should be a long random string (>=32 chars). Generate with:
#   openssl rand -hex 32
API_KEYS=
# Mutable file-based store for self-serve add/revoke (Phase 20c).
# When set, admin POST /admin/keys persists to this file. Both sources are
# read at request time; revoke from either source applies.
# Production: API_KEYS_PATH=/data/api-keys.json
API_KEYS_PATH=

# --- Limits (optional) ---
# Per-key daily token cap (UTC day). 0 = unlimited.
DAILY_TOKEN_LIMIT_PER_KEY=0
# Postgres connection for per-user usage tracking (Phase 20b). Survives
# restarts and is shared across replicas. Empty = in-memory fallback for
# tests and ad-hoc debugging — DO NOT run production without it.
#   Local dev: postgres://claude:devpassword@localhost:5433/claude_for_you
#   Production EC2: injected from SSM parameter (RDS endpoint)
DATABASE_URL=postgres://claude:devpassword@localhost:5433/claude_for_you
# Reject incoming requests when Anthropic's reported remaining-token headroom
# falls below this. 0 = disabled. Reads from anthropic-ratelimit-unified-remaining
# (subscription path) or anthropic-ratelimit-tokens-remaining.
GLOBAL_SUBSCRIPTION_THRESHOLD_TOKENS=0
# Global concurrent in-flight requests. 0 = unlimited.
MAX_CONCURRENT_REQUESTS=8
# Per-IP token bucket on /v1/messages (req/sec). burst = 2x this value.
# 0 disables. Useful when behind Caddy without the rate_limit module.
PER_IP_RATE_LIMIT_PER_SECOND=0

# --- Wire fidelity tuning (Phase 21) ---
# Minimum ms between two outbound requests sharing the same
# x-claude-code-session-id. 0 = off (default). Enable if classifier appears
# time-aware. Trusted-few traffic rarely needs this.
PACING_MIN_GAP_MS=0
# Force a specific account UUID into metadata.user_id.account_uuid for every
# outbound request. Empty = learn from anthropic-organization-id response
# headers. Set only if you've captured the exact value from a real CC OAuth
# session.
ACCOUNT_UUID_OVERRIDE=

# Canary deploy (Phase 28). When cc-snapshot.candidate.json exists next to
# cc-snapshot.json AND this is > 0, that percentage of outbound traffic uses
# the candidate template. Auto-trips on any candidate-side service_tier
# alarm — remaining traffic falls back to stable until container restart.
# Operator promote: rename candidate→cc-snapshot.json and redeploy.
# Operator rollback: delete the candidate file.
CANARY_PERCENT=0

# --- Alerts (operator notifications) ---
# Discord incoming webhook — primary alert channel. Fires on:
#   - service_tier != 'standard' or unified-status != 'allowed*'
#   - OAuth refresh failure
#   - 5xx server errors
# Each alarm class has its own 60s cooldown.
# Get one from: Discord server → Settings → Integrations → New Webhook.
DISCORD_WEBHOOK_URL=

# Slack incoming webhook — fallback if Discord URL not set.
SLACK_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=info

# --- Wire capture (Phase 17) ---
# Set CAPTURE_MODE=true on a *local* dev session to dump every authenticated
# /v1/messages request to CAPTURE_DIR. Then run drive CC through the proxy
# and Phase 18's synthesis script will fold the captures into
# src/template/cc-snapshot.json.
# NEVER enable in production — disk fills, secrets get persisted in plain.
CAPTURE_MODE=false
CAPTURE_DIR=./captures

# --- Docker compose only ---
# Domain that Caddy will provision an LE cert for. Must resolve to this host.
DOMAIN=claude.example.com
