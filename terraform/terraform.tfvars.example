# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# All variables have defaults — most deployments can leave this file empty.
# Override only what differs from the defaults below.

# region              = "ap-northeast-2"
# instance_type       = "t3.micro"
# root_volume_size_gb = 20

# If your domain lives in Route53, set both. Otherwise leave empty and
# create the A record manually with the public_ip output.
# domain_zone_id = "Z1234567890ABC"
# domain_name    = "claude.your-domain.com"

# Set this to have cloud-init clone the repo at first boot. Keep it as the
# HTTPS URL — terraform internally rewrites it to the SSH form
# (git@github.com:owner/repo.git) before handing it to git, so cloud-init
# authenticates with the SSH deploy key configured in
# /claude-for-you/github-deploy-key (see terraform/README.md →
# "Private-repo support"). For public repos with no deploy key populated,
# cloud-init falls back to anonymous HTTPS clone.
# git_repo_url = "https://github.com/your-handle/claude-for-you.git"

# Subscriber for the CloudWatch alarm SNS topic. Leave empty to create
# the topic with no subscriber (alarms still publish; just nobody
# receives them). Confirm the SNS subscription email after first apply.
# alert_email = "ops@example.com"
