# Caddy automatically provisions Let's Encrypt certificates on first request
# to {$DOMAIN}, renews them, and redirects HTTP → HTTPS.
#
# EC2 prerequisites:
#   - Security Group allows 80/tcp + 443/tcp inbound (and 80 reachable from
#     Let's Encrypt — leave it open for ACME http-01 challenge).
#   - DNS A record points {$DOMAIN} at the EC2 public IP.

# Global config — keep the auto-HTTPS issuer logs quiet on stdout, and serve
# a slim error page that doesn't leak Caddy version when something upstream
# is down.
{
	servers {
		# Helps Caddy strip hop-by-hop headers cleanly when forwarding to Bun.
		strict_sni_host insecure_off
	}
}

{$DOMAIN} {
	encode zstd gzip

	# Defense-in-depth: even though the proxy enforces application-layer
	# concurrency (MAX_CONCURRENT_REQUESTS), an attacker with a stolen API
	# key shouldn't be able to fan-out from one IP. Caddy's `request_body`
	# directive caps body size at the edge; ts-side bodyLimit catches the
	# rest. If you need true per-IP rate limiting, install the community
	# `caddy-ratelimit` module — the default Caddy build does not ship it.
	request_body {
		max_size 4MB
	}

	# Trust nothing about client identity at the edge — the app handles auth.
	# Just forward and let API-key middleware decide.
	reverse_proxy app:3456 {
		# Streaming responses need flush_interval -1 so SSE chunks aren't buffered.
		flush_interval -1
		# Timeouts. response_header_timeout (TTFB) MUST equal
		# UPSTREAM_TTFB_TIMEOUT_MS in src/proxy/upstream.ts (currently 5m).
		# If Caddy aborts before Bun gives up, the client sees a Caddy-origin 504
		# with `net/http: timeout awaiting response headers` — see
		# docs/operational-pitfalls.md #15 for the 2026-06-05 incident that put
		# the two values out of sync (Caddy at 30s, Bun at 5m).
		# read/write_timeout cover the streaming body and can stay longer than
		# the Bun ceiling; they only matter once headers have arrived.
		transport http {
			dial_timeout 10s
			response_header_timeout 5m
			read_timeout 10m
			write_timeout 10m
		}
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		# `same-origin` (not `no-referrer`) — admin form POSTs need the Referer
		# header for the CSRF guard's Origin:null fallback path. Cross-origin
		# navigations still strip Referer, which is what we actually want.
		Referrer-Policy "same-origin"
		# CORS is the client's problem — this is a back-end API, not a browser
		# service. If a browser client ever needs it, add Access-Control-* here.
	}

	log {
		output stdout
		format console
		level INFO
	}
}
